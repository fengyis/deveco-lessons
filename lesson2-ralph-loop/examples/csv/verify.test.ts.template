import { expect, test } from "bun:test"
import { parseLine } from "../src/csv"

// 独立验收测试。故意放 .ralph/(worker 扫不到、改不了),而且**用和 test/csv.test.ts
// 不一样的输入**测同样的性质 —— 这样对着可见测试硬编码字符串的作弊会在这里露馅。

// —— 普通分隔 / 空字段:这几条是「回归守门」。修引号最常见的 bug 是忘了 flush 最后一个
//    字段,于是 "x,y,z" 掉了 z、"x," 掉了尾部空字段 —— 本来绿的用例会在这里变红。——
test("普通分隔(不同输入)", () => {
  expect(parseLine("x,y,z")).toEqual(["x", "y", "z"])
})
test("尾部空字段不能丢(最常见的回归)", () => {
  expect(parseLine("x,")).toEqual(["x", ""])
})
test("连续空字段", () => {
  expect(parseLine(",,")).toEqual(["", "", ""])
})
test("全部是空字段的一行", () => {
  expect(parseLine("")).toEqual([""])
})

// —— 引号内逗号(不同输入)——
test("引号内的逗号是字面量(不同输入)", () => {
  expect(parseLine('1,"2,3,4",5')).toEqual(["1", "2,3,4", "5"])
})

// —— 转义引号(不同输入,且更刁钻)——
test("整段都是转义引号", () => {
  expect(parseLine('"""x"""')).toEqual(['"x"'])
})
test("转义引号 + 后续普通字段", () => {
  expect(parseLine('"a""b",c')).toEqual(['a"b', "c"])
})

// —— 空引号(不同位置)——
test("空引号出现在结尾", () => {
  expect(parseLine('a,""')).toEqual(["a", ""])
})

// —— 组合:引号逗号 + 空字段 + 转义,一次全上 ——
test("综合", () => {
  expect(parseLine('"a,b",,"c""d"')).toEqual(["a,b", "", 'c"d'])
})
